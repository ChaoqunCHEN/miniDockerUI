{
  "permissions": {
    "allow": [
      "Bash(swift build:*)",
      "Bash(make build:*)",
      "Bash(make tests:*)",
      "Bash(make e2e-tests:*)",
      "Bash(make autoformat:*)",
      "Bash(swift test:*)",
      "Bash(xcodebuild:*)",
      "Bash(docker ps:*)",
      "Bash(docker inspect:*)",
      "Bash(docker compose:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"/opt/homebrew/bin:$PATH\" swiftformat --quiet \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATH\" | grep -qE '\\.(env|pem|key|p12)$'; then echo 'BLOCKED: Do not edit secret/credential files' >&2; exit 1; fi"
          }
        ]
      }
    ]
  }
}
